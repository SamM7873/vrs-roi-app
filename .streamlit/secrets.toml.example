# Copy this file to `.streamlit/secrets.toml` and fill in real values.
# `.streamlit/secrets.toml` is gitignored — never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# HubSpot private-app token used for all CRM API calls.
HUBSPOT_TOKEN = "pat-na1-xxxxxxxx-your-token-here"

# Password users type on the login screen.
APP_PASSWORD = "change-me"

# Access allowlist — at least one of these must be set, or every login is denied.
# Comma-separated. Use ALLOWED_EMAILS for specific people, ALLOWED_DOMAINS for a whole org.
ALLOWED_EMAILS = "sxm1399@gmail.com"
# ALLOWED_DOMAINS = "yourcompany.com"

# ── Optional ────────────────────────────────────────────────────────────────
# Admins who can trigger privileged actions.
# ADMIN_EMAILS = "sxm1399@gmail.com"

# SMTP settings for self-service password reset emails (only needed if you use it).
# SMTP_HOST = "smtp.gmail.com"
# SMTP_PORT = "587"
# SMTP_USER = "you@gmail.com"
# SMTP_PASSWORD = "your-app-password"
# SMTP_FROM = "you@gmail.com"
